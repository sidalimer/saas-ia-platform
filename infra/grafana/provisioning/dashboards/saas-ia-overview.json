  "schemaVersion": 39,
  "tags": ["saas-ia", "microservices"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": "Prometheus",
        "definition": "label_values(http_requests_total, service)",
        "includeAll": true,
        "label": "Service",
        "multi": true,
        "name": "service",
        "options": [],
        "query": "label_values(http_requests_total, service)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "SaaS IA — Vue d'ensemble microservices",
  "uid": "saas-ia-overview",
  "version": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Requetes / s (total)",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        { "datasource": "Prometheus", "expr": "sum(rate(http_requests_total{service=~\"$service\"}[5m]))", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Taux d'erreur 5xx",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.01 }, { "color": "red", "value": 0.05 }] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        { "datasource": "Prometheus", "expr": "sum(rate(http_requests_total{service=~\"$service\", status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{service=~\"$service\"}[5m])), 1)", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Latence p95 (global)",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.5 }, { "color": "red", "value": 1 }] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{service=~\"$service\"}[5m])))", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Services UP",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        { "datasource": "Prometheus", "expr": "count(up == 1)", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Trafic par service (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "stacking": { "mode": "normal", "group": "A" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": "Prometheus", "expr": "sum by (service) (rate(http_requests_total{service=~\"$service\"}[5m]))", "legendFormat": "{{service}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latence p95 par service",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.95, sum by (le, service) (rate(http_request_duration_seconds_bucket{service=~\"$service\"}[5m])))", "legendFormat": "{{service}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Erreurs par statut HTTP (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "stacking": { "mode": "normal", "group": "A" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": "Prometheus", "expr": "sum by (status_code) (rate(http_requests_total{service=~\"$service\", status_code=~\"[45]..\"}[5m]))", "legendFormat": "{{status_code}}", "refId": "A" }
      ]
    },
    {
      "type": "table",
      "title": "Top routes (req totales)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": "Prometheus",
      "options": { "showHeader": true },
      "targets": [
        { "datasource": "Prometheus", "expr": "topk(10, sum by (service, route, method) (increase(http_requests_total{service=~\"$service\"}[1h])))", "format": "table", "instant": true, "refId": "A" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "Requetes (1h)" } } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memoire residente par service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": "Prometheus", "expr": "process_resident_memory_bytes{service=~\"$service\"}", "legendFormat": "{{service}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU par service (cores)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(process_cpu_seconds_total{service=~\"$service\"}[5m])", "legendFormat": "{{service}}", "refId": "A" }
      ]
    }
  ]
}
