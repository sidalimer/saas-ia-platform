# ============================================================
# SaaS IA Platform — Environment Variables
# Copy this file to .env before running: cp .env.example .env
# ============================================================

# ---- General ----
NODE_ENV=development
LOG_LEVEL=debug

# ---- Internal Service Communication ----
INTERNAL_API_KEY=dev-internal-key-change-me

# ---- PostgreSQL ----
POSTGRES_USER=saasia
POSTGRES_PASSWORD=saasia_dev_password
POSTGRES_DB=saasia
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://saasia:saasia_dev_password@postgres:5432/saasia?schema=public

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ---- JWT ----
JWT_ACCESS_SECRET=dev-access-secret-change-me-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- OAuth2 / OIDC — Google ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/oauth/google/callback

# ---- OAuth2 / OIDC — GitHub ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8080/api/auth/oauth/github/callback

# ---- OAuth2 / OIDC — Discord ----
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:8080/api/auth/oauth/discord/callback

# ---- Email (MailHog in dev) ----
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@saas-ia.local

# ---- SMS — Twilio (optional, fallback to console) ----
SMS_MODE=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ---- Google Gemini AI (optional, fallback to mock) ----
GEMINI_API_KEY=

# ---- Push Notifications — Firebase (optional, fallback to console) ----
FIREBASE_SERVER_KEY=

# ---- Stripe (test mode) ----
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Service URLs (internal Docker network) ----
DB_SERVICE_URL=http://db-service:4001
AUTH_SERVICE_URL=http://auth-service:4002
NOTIFICATION_SERVICE_URL=http://notification-service:4003
AI_SERVICE_URL=http://ai-service:4004
PAYMENT_SERVICE_URL=http://payment-service:4005
METRICS_SERVICE_URL=http://metrics-service:4006
GATEWAY_URL=http://gateway:8080

# ---- Frontend ----
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8080

# ---- Grafana ----
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
